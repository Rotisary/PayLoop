enum MandateStatus {
  PENDING
  SUBMITTED
  APPROVED
  PAUSED
  CANCELLED
}

model Mandate {
  id                 String        @id @default(uuid()) @db.Uuid
  merchantId         String        @db.Uuid
  merchant           Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  environment        Environment
  providerMandateId  String?
  status             MandateStatus  @default(PENDING)

  startDate          DateTime
  endDate            DateTime
  providerCreatedAt  DateTime?      @map("created_at")

  customerId         String        @db.Uuid
  customer           Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  amount             Int

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([merchantId, environment, providerMandateId])
  @@index([merchantId, environment])
  @@index([merchantId, environment, status])
  @@index([customerId])
}